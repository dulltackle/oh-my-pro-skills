{
  "name": "smart-illustrator-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "init": "npm install",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/live/**",
    "test:live": "vitest run tests/live",
    "test:all": "npm run test && npm run test:live"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
